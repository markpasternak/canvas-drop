# canvas-drop configuration (BUILD_BRIEF.md §8.1)
#
# Quickstart:  cp .env.example .env && pnpm dev
# The defaults below boot a zero-config localhost instance:
#   path mode + SQLite + local file storage + dev auth.
# Every variable is validated at boot; invalid combinations fail loudly with a
# precise message naming the variable to fix.

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
# path = localhost / trusted single-host;  subdomain = recommended production
CANVAS_DROP_URL_MODE=path
# subdomain mode example: https://canvases.example.com  (canvases at *.canvases.example.com)
CANVAS_DROP_BASE_URL=http://localhost:3000
CANVAS_DROP_PORT=3000
# 256-bit random string. REQUIRED outside dev mode (and always in production).
# Generate: openssl rand -hex 32
# CANVAS_DROP_SESSION_SECRET=
# Comma-separated bootstrap admins (defaults to the dev user in dev mode).
# CANVAS_DROP_ADMIN_EMAILS=admin@example.com
CANVAS_DROP_REALTIME=on
# Remote MCP server + its OAuth endpoints (the connect-once agent control plane).
# On by default; set to `off` to drop the /mcp surface entirely.
CANVAS_DROP_MCP=on
# Explicit unsafe opt-in for multi-user path mode (reduced isolation, §12.2).
CANVAS_DROP_ALLOW_MULTI_USER_PATH_MODE=false
# Where the built dashboard SPA lives. Defaults to a path resolved from the
# server module (apps/dashboard/dist); override only for non-standard layouts.
# CANVAS_DROP_DASHBOARD_DIST=/app/dashboard/dist

# Rate limiting (§12.3, M7). Per-class requests/minute; the master flag toggles
# all enforcement. Keyed by the server-resolved user (and canvas for runtime);
# login keys on the resolved client IP. Window is fixed at 60s, counters live
# in-process (reset on restart). Defaults suit a small trusted org on one host.
CANVAS_DROP_RATELIMIT_ENABLED=true
CANVAS_DROP_RATELIMIT_CANVAS_API_PER_MIN=120  # KV/files from canvas code (~2 req/s/user/canvas)
CANVAS_DROP_RATELIMIT_AI_PER_MIN=10           # AI proxy — real $ per call; cost/abuse cap
CANVAS_DROP_RATELIMIT_DEPLOY_PER_MIN=10       # publishes (heavy, infrequent) per canvas
CANVAS_DROP_RATELIMIT_MANAGEMENT_PER_MIN=120  # dashboard /api/* per user; SPA bursts on nav
CANVAS_DROP_RATELIMIT_LOGIN_PER_MIN=10        # per resolved client IP — see TRUSTED_PROXY_IPS
CANVAS_DROP_RATELIMIT_PASSWORD_GATE_PER_MIN=5 # brute-force defense on protected-canvas passwords

# ─── Database (SQLite or Postgres behind one Drizzle schema) ──────────────────
CANVAS_DROP_DB=sqlite
CANVAS_DROP_SQLITE_PATH=./data/canvasdrop.db
# Required when CANVAS_DROP_DB=postgres:
# CANVAS_DROP_DATABASE_URL=postgres://user:pass@localhost:5432/canvasdrop

# ─── Storage (local disk or any S3-compatible endpoint) ──────────────────────
CANVAS_DROP_STORAGE=local
CANVAS_DROP_STORAGE_PATH=./data/storage
# Required when CANVAS_DROP_STORAGE=s3 (AWS S3, MinIO, Cloudflare R2, …):
# CANVAS_DROP_S3_ENDPOINT=https://s3.amazonaws.com   # custom endpoint for MinIO/R2
# CANVAS_DROP_S3_BUCKET=canvases
# CANVAS_DROP_S3_REGION=us-east-1
# CANVAS_DROP_S3_ACCESS_KEY=
# CANVAS_DROP_S3_SECRET_KEY=
# CANVAS_DROP_S3_FORCE_PATH_STYLE=true               # true for MinIO

# ─── Auth ────────────────────────────────────────────────────────────────────
# proxy = recommended production (front the app with an identity-aware proxy)
# oidc  = built-in login fallback for self-hosters without an IAP
# dev   = auto-login a fake local user, zero setup (localhost only)
CANVAS_DROP_AUTH_MODE=dev
# Enforced by the app on every request, in every mode. Defaults to the dev
# user's domain in dev mode.
# CANVAS_DROP_ALLOWED_EMAIL_DOMAINS=example.com,example.org

# --- proxy mode -------------------------------------------------------------
# Recommended: verify the proxy's signed identity JWT against its JWKS.
# Example below is for Cloudflare Access; oauth2-proxy / Google IAP also emit a JWT.
# CANVAS_DROP_AUTH_PROXY_JWT_JWKS_URL=https://<team>.cloudflareaccess.com/cdn-cgi/access/certs
# CANVAS_DROP_AUTH_PROXY_JWT_ISSUER=https://<team>.cloudflareaccess.com
# CANVAS_DROP_AUTH_PROXY_JWT_AUDIENCE=<application-audience-tag>
# Header carrying the signed identity JWT (default suits Cloudflare Access; set to
# whatever your proxy emits its verifiable identity JWT in). When JWKS is set, this
# is the ONLY trust path — the trusted-header path below is disabled.
# CANVAS_DROP_AUTH_PROXY_JWT_HEADER=Cf-Access-Jwt-Assertion
# Alternative (used ONLY when no JWKS URL is set above): trust a forwarded
# identity header, but ONLY from these hops. IPv4 addresses/CIDRs only; /0 is
# rejected. The app must never be directly reachable; the proxy must overwrite
# the header. For IPv6 proxies, use the JWT path above.
# This list ALSO makes the login rate limit per-user behind a reverse proxy: when
# the socket peer is a trusted hop, the real client IP is read from
# X-Forwarded-For (otherwise every client shares the proxy's single bucket). Set
# it to your proxy's egress even in oidc mode — e.g. 127.0.0.1 for a local Caddy.
# CANVAS_DROP_TRUSTED_PROXY_IPS=10.0.0.0/8
# Header carrying the verified email (default X-Auth-Request-Email suits
# oauth2-proxy; Cloudflare Access uses Cf-Access-Authenticated-User-Email).
# CANVAS_DROP_AUTH_PROXY_EMAIL_HEADER=X-Auth-Request-Email
# CANVAS_DROP_AUTH_PROXY_NAME_HEADER=X-Auth-Request-Preferred-Username

# --- oidc fallback mode -----------------------------------------------------
# CANVAS_DROP_OIDC_ISSUER=https://accounts.google.com
# CANVAS_DROP_OIDC_CLIENT_ID=
# CANVAS_DROP_OIDC_CLIENT_SECRET=

# --- dev mode ---------------------------------------------------------------
CANVAS_DROP_DEV_USER_EMAIL=dev@example.com
CANVAS_DROP_DEV_USER_NAME=Dev User

# ─── AI primitive (Anthropic-first LLM proxy, M9) ───────────────────────────────
# The AI capability is OFF until a provider key is set (an empty key does NOT
# enable it). The key is server-side only and never reaches the browser.
CANVAS_DROP_AI_PROVIDER=anthropic
# CANVAS_DROP_AI_API_KEY=                    # server-side only, never in the browser
# CANVAS_DROP_AI_BASE_URL=                   # optional gateway/proxy override
# Admin allowlist of callable model IDs (out-of-list requests are rejected).
CANVAS_DROP_AI_MODELS=claude-haiku-4-5,claude-sonnet-4-6,claude-opus-4-8
CANVAS_DROP_AI_USER_DAILY_USD=5             # per-user daily USD quota
CANVAS_DROP_AI_CANVAS_MONTHLY_USD=50        # per-canvas monthly USD quota

# ─── Email (guest invites) ───────────────────────────────────────────────────
# Driver for sending guest-invite magic links. `log` (default) writes the message
# + link to the server log — zero-setup for local dev. `smtp` sends via any SMTP
# server. `mailgun` sends via the Mailgun HTTP API. `noop` disables email (guest
# invites are refused cleanly). Email provider secrets are server-side only and
# never logged — invite emails are auth credentials.
CANVAS_DROP_EMAIL_DRIVER=log
# CANVAS_DROP_EMAIL_FROM=                     # sender; defaults to no-reply@<mailgun domain>
# SMTP (only when CANVAS_DROP_EMAIL_DRIVER=smtp).
# CANVAS_DROP_SMTP_HOST=                      # e.g. smtp.example.com
# CANVAS_DROP_SMTP_PORT=587                   # 587 = STARTTLS (default), 465 = implicit TLS
# CANVAS_DROP_SMTP_USER=                      # omit user+pass for an IP-allowlisted relay
# CANVAS_DROP_SMTP_PASS=
# CANVAS_DROP_SMTP_SECURE=false               # true for port 465 (implicit TLS)
# Mailgun (only when CANVAS_DROP_EMAIL_DRIVER=mailgun).
# CANVAS_DROP_MAILGUN_API_KEY=
# CANVAS_DROP_MAILGUN_DOMAIN=                 # e.g. mg.example.com
# CANVAS_DROP_MAILGUN_BASE_URL=https://api.mailgun.net   # use https://api.eu.mailgun.net for EU

# ─── Logging (structured JSON to stdout; pretty for local dev) ────────────────
LOG_LEVEL=info
# LOG_FORMAT=pretty                          # defaults: pretty in dev, json in production

# ─── Error tracking (optional, off unless configured) ─────────────────────────
# CANVAS_DROP_SENTRY_DSN=
