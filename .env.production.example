# canvas-drop — PRODUCTION configuration example (BUILD_BRIEF §8.1, §8.4).
#
# This is the "blessed" production profile: subdomain URLs · proxy auth (JWKS) ·
# Postgres · S3-compatible storage. Copy it, replace every CHANGE_ME / REPLACE_ME
# placeholder, and supply it to your process manager or container env — NOT a
# committed .env file. Every value is validated at boot; invalid combinations fail
# loudly naming the variable to fix.
#
# For a zero-setup *local* instance, use `.env.example` instead (dev defaults).
# The docker-compose.yml demo approximates this profile with a bundled IdP — see
# docs/site/self-hosting/deploy.md.

NODE_ENV=production

# ─── URLs ────────────────────────────────────────────────────────────────────
# subdomain mode = per-canvas origin isolation ({slug}.{base}). REQUIRES real
# wildcard DNS (*.canvases.example.com) and a wildcard TLS cert at your proxy.
# (The localhost docker demo uses `path` mode because subdomain can't boot on
# localhost — it needs that real DNS + cert.)
CANVAS_DROP_URL_MODE=subdomain
CANVAS_DROP_BASE_URL=https://canvases.example.com
# Where the Deploy API (/v1/canvases/*) is reachable by agents/CI. Defaults to
# CANVAS_DROP_BASE_URL. Set it when the API is fronted on a dedicated host (common
# in subdomain mode): the MCP tools advertise curl endpoints built from this so
# agents don't probe for the host. `api`/`v1`/`sdk`/`auth`/`mcp` are reserved slugs,
# so a canvas can't collide with it.
# CANVAS_DROP_API_BASE_URL=https://api.canvases.example.com
CANVAS_DROP_PORT=3000

# 256-bit random string. REQUIRED in production. Generate: openssl rand -hex 32
CANVAS_DROP_SESSION_SECRET=REPLACE_ME__run_openssl_rand_hex_32__min_32_chars

# ─── Auth: proxy mode, JWKS (cryptographic) trust path (§12.5) ────────────────
# Front the app with an identity-aware proxy / IAP that asserts a signed identity
# JWT. The app verifies the JWT against the proxy's JWKS — the preferred,
# cryptographic path. (The weaker trusted-header path exists for proxies that
# can't mint a JWT; see CANVAS_DROP_TRUSTED_PROXY_IPS in .env.example.)
CANVAS_DROP_AUTH_MODE=proxy
# Header the proxy forwards the signed JWT in (default suits Cloudflare Access).
CANVAS_DROP_AUTH_PROXY_JWT_HEADER=Cf-Access-Jwt-Assertion
CANVAS_DROP_AUTH_PROXY_JWT_JWKS_URL=https://idp.example.com/.well-known/jwks.json
CANVAS_DROP_AUTH_PROXY_JWT_ISSUER=https://idp.example.com
CANVAS_DROP_AUTH_PROXY_JWT_AUDIENCE=canvas-drop
# Enforced on every request, in every mode. CSV, lowercased.
CANVAS_DROP_ALLOWED_EMAIL_DOMAINS=example.com
# Comma-separated bootstrap admins.
CANVAS_DROP_ADMIN_EMAILS=admin@example.com

# ─── Serving / CDN (optional — only if a CDN fronts this instance) ───────────
# If you put a CDN (Cloudflare, Fastly, …) in front, set these. See the operator
# guide: docs/site/self-hosting/cdn.md.
# The trusted hops the real client IP may be read from (the CDN's egress, plus any
# local reverse proxy). Without it, every request buckets under the CDN's IP for
# rate-limiting and audit logging. IPv4/CIDR only.
# CANVAS_DROP_TRUSTED_PROXY_IPS=173.245.48.0/20,103.21.244.0/22
# The header your CDN puts the real client IP in (read only from a trusted hop above).
# CANVAS_DROP_CLIENT_IP_HEADER=True-Client-IP
# Seconds a CDN may edge-cache a public canvas's HTML (s-maxage); also the staleness
# window after an owner restricts a canvas. 0 disables shared caching. Default 300.
# CANVAS_DROP_PUBLIC_EDGE_CACHE_TTL=300

# ─── Database: Postgres ──────────────────────────────────────────────────────
CANVAS_DROP_DB=postgres
CANVAS_DROP_DATABASE_URL=postgres://canvasdrop:CHANGE_ME@db.internal:5432/canvasdrop

# ─── Storage: S3-compatible ──────────────────────────────────────────────────
CANVAS_DROP_STORAGE=s3
CANVAS_DROP_S3_BUCKET=canvas-drop
CANVAS_DROP_S3_REGION=us-east-1
CANVAS_DROP_S3_ACCESS_KEY=CHANGE_ME_access_key
CANVAS_DROP_S3_SECRET_KEY=CHANGE_ME_secret_key
# For MinIO / Cloudflare R2, set a custom endpoint (and path-style for MinIO):
# CANVAS_DROP_S3_ENDPOINT=https://s3.example.com
# CANVAS_DROP_S3_FORCE_PATH_STYLE=true

# ─── AI primitive (optional — OFF until a key is set) ────────────────────────
# Server-side only; never reaches the browser.
# CANVAS_DROP_AI_PROVIDER=anthropic
# CANVAS_DROP_AI_API_KEY=
# CANVAS_DROP_AI_MODELS=claude-haiku-4-5,claude-sonnet-4-6,claude-opus-4-8
# CANVAS_DROP_AI_USER_DAILY_USD=5
# CANVAS_DROP_AI_CANVAS_MONTHLY_USD=50

# ─── Email (optional — guest invites) ────────────────────────────────────────
# `log` (default) writes the link to the server log; `smtp`/`mailgun` send real mail.
# CANVAS_DROP_EMAIL_DRIVER=smtp
# CANVAS_DROP_EMAIL_FROM=no-reply@example.com
# CANVAS_DROP_SMTP_HOST=smtp.example.com
# CANVAS_DROP_SMTP_PORT=587

# ─── Observability (optional) ────────────────────────────────────────────────
# LOG_LEVEL=info        # default info
# LOG_FORMAT=json       # json in production (default), pretty in dev
# CANVAS_DROP_SENTRY_DSN=   # error tracking off unless set; no telemetry otherwise
