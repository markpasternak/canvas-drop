{
  "name": "canvas-drop",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hostable platform where org members deploy and share small static web artifacts (\"canvases\"), with five built-in backend primitives: KV, files, AI, identity, realtime.",
  "license": "MIT",
  "author": "Mark Pasternak",
  "homepage": "https://github.com/markpasternak/canvas-drop#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markpasternak/canvas-drop.git"
  },
  "bugs": {
    "url": "https://github.com/markpasternak/canvas-drop/issues"
  },
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env scripts/dev.mjs",
    "dev:fresh": "pnpm reset:data && pnpm seed:canvases && pnpm dev",
    "dev:stop": "node scripts/dev-stop.mjs",
    "dev:restart": "node scripts/dev-stop.mjs && node --env-file-if-exists=.env scripts/dev.mjs",
    "build": "pnpm -r build",
    "test": "node scripts/test-runner.mjs full",
    "test:watch": "vitest",
    "test:sqlite": "node scripts/test-runner.mjs root --dialect sqlite",
    "test:pg": "node scripts/test-runner.mjs root --dialect postgres",
    "test:dashboard": "node scripts/test-runner.mjs dashboard",
    "test:file": "node scripts/test-runner.mjs file",
    "purge": "pnpm --filter @canvas-drop/server run purge",
    "backup": "pnpm --filter @canvas-drop/server run backup",
    "restore": "pnpm --filter @canvas-drop/server run restore",
    "seed:showcase": "pnpm --filter @canvas-drop/server exec tsx scripts/seed-showcase.ts",
    "reset:data": "pnpm --filter @canvas-drop/server exec tsx scripts/reset-data.ts",
    "backfill:search-text": "pnpm --filter @canvas-drop/server exec tsx scripts/backfill-search-text.ts",
    "seed:canvases": "pnpm --filter @canvas-drop/server exec tsx scripts/seed-canvases.ts",
    "seed:demo-apps": "pnpm --filter @canvas-drop/server exec tsx scripts/seed-demo-apps.ts",
    "seed:usage": "pnpm --filter @canvas-drop/server exec tsx scripts/seed-usage.ts",
    "docs:build": "node scripts/build-docs.mjs",
    "docs:watch": "node scripts/build-docs.mjs --watch",
    "docs:screenshots": "node scripts/screenshots.mjs",
    "landing:screenshots": "node scripts/screenshots.mjs --landing",
    "og:build": "node scripts/og-card.mjs",
    "landing:carousel": "esbuild scripts/landing-carousel.src.mjs --bundle --format=iife --minify --target=es2019 --outfile=docs/site/assets/landing-carousel.js",
    "docs:mermaid": "esbuild scripts/docs-mermaid.src.mjs --bundle --format=iife --minify --target=es2020 --outfile=docs/site/assets/mermaid.js",
    "landing:gif": "node scripts/landing-gif.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm --filter @canvas-drop/sdk typecheck && pnpm --filter @canvas-drop/dashboard typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "drizzle-kit": "^0.31.10",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "esbuild": "^0.28.1",
    "highlight.js": "11.11.1",
    "marked": "14.1.4",
    "playwright": "^1.49.0",
    "sanitize-html": "2.17.5",
    "sharp": "^0.35.1",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "mermaid": "11.15.0"
  }
}
