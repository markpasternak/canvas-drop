{
  "name": "canvas-drop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm --filter @canvas-drop/server dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:sqlite": "CANVAS_DROP_DB=sqlite vitest run",
    "test:pg": "CANVAS_DROP_DB=postgres vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
