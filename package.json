{
  "name": "canvas-drop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env scripts/dev.mjs",
    "build": "pnpm -r build",
    "test": "vitest run && pnpm --filter @canvas-drop/dashboard test",
    "test:watch": "vitest",
    "test:sqlite": "CANVAS_DROP_DB=sqlite vitest run",
    "test:pg": "CANVAS_DROP_DB=postgres vitest run",
    "test:dashboard": "pnpm --filter @canvas-drop/dashboard test",
    "purge": "pnpm --filter @canvas-drop/server run purge",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json && pnpm --filter @canvas-drop/sdk typecheck && pnpm --filter @canvas-drop/dashboard typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
