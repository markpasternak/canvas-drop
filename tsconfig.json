{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": ["packages/*/src/**/*.ts", "apps/*/src/**/*.ts"],
  // The dashboard (React/JSX, DOM lib) and the browser SDK (DOM lib) are
  // type-checked by their own tsconfigs, invoked by the root `typecheck` script.
  // Excluded here so the server never inherits a DOM lib.
  "exclude": ["apps/dashboard", "packages/sdk"]
}
