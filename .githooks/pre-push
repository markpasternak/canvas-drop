#!/usr/bin/env bash
# Pre-push gate — best-effort local stand-in for server-side branch protection
# (GitHub requires Pro to protect a private repo's branches). Blocks a push to
# main unless lint, typecheck, and the dual-dialect test suite pass.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Bypass in an emergency: git push --no-verify
set -euo pipefail

protected="refs/heads/main"
pushing_to_main=false
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [ "$remote_ref" = "$protected" ]; then pushing_to_main=true; fi
done

if [ "$pushing_to_main" = false ]; then
  exit 0
fi

echo "pre-push: validating before pushing to main (lint, typecheck, tests)…"
pnpm lint
pnpm typecheck
pnpm test
echo "pre-push: all gates green ✓"
