{
  "name": "@canvas-drop/sdk",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./bundle": "./dist/sdk.v1.js"
  },
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/browser-entry.ts --bundle --format=iife --minify --outfile=dist/sdk.v1.js",
    "dev": "esbuild src/browser-entry.ts --bundle --format=iife --outfile=dist/sdk.v1.js --watch"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
